{
  "manifest_version": 3,
  "name": "Codeforces Tag Hider",
  "version": "1.1",
  "description": "Hides algorithm tags but keeps difficulty ratings (*1400, etc).",
  "browser_specific_settings": {
    "gecko": {
      "id": "cftaghider@myextension.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://codeforces.com/*", "*://*.codeforces.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}