{
  "manifest_version": 3,
  "name": "Gemini Toggle",
  "version": "1.0",
  "action": {},
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://gemini.google.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "toggle-action": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Toggle Gemini"
    }
  }
}